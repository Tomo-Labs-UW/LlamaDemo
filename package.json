{
  "name": "tomomize",
  "version": "1.0.0",
  "description": "TomoTube - Simplifying text with AI",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend && npm run build -w backend",
    "start": "npm start -w backend",
    "preview": "npm run preview -w frontend"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
