{
  "version": 2,
  "builds": [
    { "src": "api/[...all].js", "use": "@vercel/node" },
    { "src": "frontend/public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/[...all].js" },
    { "src": "^/$", "dest": "/frontend/public/index.html" },
    { "src": "^/(.*)$", "dest": "/frontend/public/$1" }
  ]
}
